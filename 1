name: App-Bus
description: Central de Gestão, Monitoramento e Auditoria do Transporte Escolar - SEMEC.
version: 1.0.0

environment:
  sdk: '>=3.0.0 <4.0.0'

dependencies:
  flutter:
    sdk: flutter

  # Interface e Componentes Visuais
  fluent_ui: ^4.7.1
  sidebarx: ^0.15.0
  
  # Gráficos Analíticos
  fl_chart: ^0.66.0
  
  # Gerenciamento de Estado
  provider: ^6.1.1
  
  # Comunicação com a API Backend (FastAPI)
  http: ^1.2.0
  intl: ^0.19.0

  # Utilitários de Controle de Janela Nativa (Windows)
  window_manager: ^0.3.8

dev_dependencies:
  flutter_test:
    sdk: flutter
  flutter_lints: ^3.0.0

# Esta regra força o Flutter a ignorar o conflito e usar a versão correta
dependency_overrides:
  intl: ^0.20.2

flutter:
  uses-material-design: true